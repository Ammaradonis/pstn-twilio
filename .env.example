# Backend
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=https://webfitalchemist.online
WEB_APP_URL=http://localhost:5173

# Database (Neon/Postgres)
# Example: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=
DIRECT_DATABASE_URL=

# Redis (Upstash or other)
REDIS_URL=

# Sessions / Auth
SESSION_SECRET=change-me
JWT_SECRET=change-me
COOKIE_DOMAIN=localhost
CORS_ORIGINS=http://localhost:5173
BOOTSTRAP_TOKEN=
# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_DEFAULT_COUNTRY=US
TWILIO_WEBHOOK_BASE_URL=https://webfitalchemist.online
TWILIO_VOICE_STATUS_CALLBACK_URL=$TWILIO_WEBHOOK_BASE_URL/webhooks/twilio/voice/status
TWILIO_MESSAGING_STATUS_CALLBACK_URL=$TWILIO_WEBHOOK_BASE_URL/webhooks/twilio/messaging/status

# Owner bootstrap (use only once in a safe environment)
OWNER_EMAIL=owner@example.com
OWNER_INITIAL_PASSWORD=changeme

# Cloudflare / Deployment (optional)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
NAMECHEAP_DOMAIN=webfitalchemist.online

# Other
VITE_API_BASE_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000
VITE_APP_NAME=pstn-twilio
