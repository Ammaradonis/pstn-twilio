{
  "name": "pstn-twilio",
  "version": "0.0.0",
  "private": true,
  "description": "Provision Twilio numbers, send/receive SMS, and answer/place PSTN calls in the browser.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.0.0",
  "scripts": {
    "dev": "pnpm run --parallel --filter \"./apps/*\" dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\"",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter @pstn-twilio/web run test:e2e",
    "prisma:generate": "pnpm --filter @pstn-twilio/api run prisma:generate",
    "prisma:migrate": "pnpm --filter @pstn-twilio/api run prisma:migrate",
    "prisma:format": "pnpm --filter @pstn-twilio/api run prisma:format",
    "prisma:studio": "pnpm --filter @pstn-twilio/api run prisma:studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
