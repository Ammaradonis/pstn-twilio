# Production environment template.
# Fill these in as Fly secrets / Render secret env vars / Cloudflare Pages env.
# Do NOT commit this file with real values.

# ────────────────────── API runtime ──────────────────────
NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://api.webfitalchemist.online
WEB_APP_URL=https://app.webfitalchemist.online
CORS_ORIGINS=https://app.webfitalchemist.online
COOKIE_DOMAIN=webfitalchemist.online

# ────────────────────── Database ─────────────────────────
DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require
DIRECT_DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require

# ────────────────────── Redis ────────────────────────────
REDIS_URL=rediss://<host>:<port>?password=<password>

# ────────────────────── Auth ─────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
SESSION_SECRET=
# Set once to seed the owner via /api/auth/bootstrap-owner. Unset after first use.
BOOTSTRAP_TOKEN=
OWNER_EMAIL=
OWNER_INITIAL_PASSWORD=

# ────────────────────── Twilio ───────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_DEFAULT_COUNTRY=US
TWILIO_WEBHOOK_BASE_URL=https://api.webfitalchemist.online
TWILIO_VOICE_STATUS_CALLBACK_URL=https://api.webfitalchemist.online/webhooks/twilio/voice/status
TWILIO_MESSAGING_STATUS_CALLBACK_URL=https://api.webfitalchemist.online/webhooks/twilio/messaging/status

# ────────────────────── Cloudflare (CI / deploy) ─────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
NAMECHEAP_DOMAIN=webfitalchemist.online

# ────────────────────── Frontend build ───────────────────
# These are read at build time by Vite; ship them in Cloudflare Pages env, not Fly.
VITE_API_BASE_URL=https://api.webfitalchemist.online/api
VITE_WS_URL=wss://api.webfitalchemist.online
VITE_APP_NAME=pstn-twilio
